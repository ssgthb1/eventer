# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (email invitations — OPTIONAL in Phase 1.5) ──────
# Only required when INVITES_ENABLED=true. Phase 1 uses word-of-mouth
# (organizer adds participants manually); leave blank to disable.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Twilio (SMS invitations — OPTIONAL in Phase 1.5) ────────
# Only required when INVITES_ENABLED=true. Leave blank to disable.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Feature flags ───────────────────────────────────────────
# Set to true to surface the InviteForm UI on the participants page.
# Requires the Resend + Twilio secrets above to be configured.
INVITES_ENABLED=false

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
